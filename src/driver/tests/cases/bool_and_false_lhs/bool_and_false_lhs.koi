// a > b is false (0); c < 100 is true (1).
// false && true must be false → skip the if → return 0.
//
// Register-clobbering bug: the second comparison stores 1 in AL,
// overwriting the first result, so both operands of && become 1
// and the expression incorrectly evaluates to true.
func main() int {
    a := 5
    b := 10
    c := 3
    if a > b && c < 100 {
        return 1
    }
    return 0
}
