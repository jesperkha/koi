// a > b is true (1); c < 100 is false (0).
// true || false must be true → enter the if → return 1.
//
// Register-clobbering bug: the second comparison stores 0 in AL,
// overwriting the first result, so both operands of || become 0
// and the expression incorrectly evaluates to false.
func main() int {
    a := 10
    b := 5
    c := 200
    if a > b || c < 100 {
        return 1
    }
    return 0
}
