// a > b (F) && c < 10 (T) || a + b == c (T)
// = (false && true) || true = false || true = true → return 1.
//
// Tests mixed && / || precedence with a chained expression.
// && binds tighter, so this is ((a > b) && (c < 10)) || (a + b == c).
// a=1, b=2, c=3: 1>2=F, 3<10=T, 1+2==3=T → (F&&T)||T = T.
func main() int {
    a := 1
    b := 2
    c := 3
    if a > b && c < 10 || a + b == c {
        return 1
    }
    return 0
}
