// continue in a for loop must still execute the post-increment step before
// re-checking the condition.
//
// Bug in the C backend: for-loops are emitted as
//   while(1) { cond_check; body; post; }
// A C `continue` jumps to the top of while(1) and skips `post`. When
// counter==5 triggers continue, i is NOT incremented (stays 4), so i lags
// behind by 1 for all subsequent iterations.
//
// Correct (x86): when counter==10, i==9. Return 9.
// Buggy  (C):    when counter==10, i==8. Return 8 → test fails.
func main() int {
    counter := 0
    for i := 0; i < 10; i = i + 1 {
        counter = counter + 1
        if counter == 5 {
            continue
        }
        if counter == 10 {
            return i
        }
    }
    return 0
}
