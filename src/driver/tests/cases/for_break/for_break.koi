// break inside a for loop must exit the loop immediately, with the
// post-increment not running for the iteration that hits break.
// Loop exits when i==5; result is 5.
func main() int {
    result := 0
    for i := 0; i < 10; i = i + 1 {
        result = i
        if i == 5 {
            break
        }
    }
    return result
}
